<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <form action="/campgrounds/<%= campgrounds._id %>?_method=PUT" method="POST">
        <div>
            <label for="title">Title</label>
            <input type="text" id="title" name="campground[title]" value="<%=campgrounds.title %>">
        </div>
         <div>
            <label for="location">Location</label>
            <input type="text" id="location" name="campground[location]" value="<%=campgrounds.location %>">
        </div>
        <button>Save Campground</button>
        <a href="/campgrounds/<%= campgrounds._id %>">Back to Campground</a>
    </form>
</body>
</html>